{
  "name": "@mini-swe-agent/debug-web",
  "version": "1.0.0",
  "private": true,
  "description": "Web debugger for mini-swe-agent traces.",
  "type": "module",
  "scripts": {
    "build": "tsc && vite build",
    "dev": "vite --host 127.0.0.1",
    "preview": "vite preview --host 127.0.0.1",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@mini-swe-agent/debug-kit": "workspace:*",
    "@vitejs/plugin-react": "^5.1.1",
    "vite": "^7.3.0",
    "lucide-react": "^0.561.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
